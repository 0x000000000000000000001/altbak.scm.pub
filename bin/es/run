#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/../.."

mkdir -p bak/es/output-purs bak/js/spago
rm -rf output .spago spago.yaml spago.lock
ln -s bak/es/output-purs output
ln -s bak/js/spago .spago
ln -s bak/js/spago.yaml spago.yaml
touch bak/es/spago.lock && ln -s bak/es/spago.lock spago.lock

ENTRY_POINT="App"

if [ "$1" == "--x" ]; then
  ENTRY_POINT="AppX"
  # Temporarily inject extended tests
  cp -r srx/Test/* src/Test/
  cp srx/AppX.purs src/
  trap "rm -rf src/Test/STArray.purs src/Test/AffOperations.purs src/Test/StringOps.purs src/Test/FileOps src/AppX.purs" EXIT
fi

export PATH="$PWD/bak/js/node_modules/.bin:$PATH"
spago build > /dev/null 2>&1
purs-backend-es build --output-dir bak/es/output > /dev/null 2>&1
find bak/es/output-purs -name "foreign.js" | while read -r f; do
  dest="bak/es/output/$(basename $(dirname $f))"
  mkdir -p "$dest"
  cp "$f" "$dest/foreign.js"
done


echo "=== Arista ES ==="
time node -e "import('./bak/es/output/' + '$ENTRY_POINT' + '/index.js').then(m => m.main())"
