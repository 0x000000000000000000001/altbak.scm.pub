#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/../.."

mkdir -p bak/php/output bak/php/spago
rm -rf output .spago spago.yaml spago.lock
ln -s bak/php/output output
ln -s bak/php/spago .spago
ln -s bak/php/spago.yaml spago.yaml
touch bak/php/spago.lock && ln -s bak/php/spago.lock spago.lock

# Note: phpurs is expected to be installed globally via `npm link`
echo "Compiling via phpurs (expect this to fail if features are missing)..."
npx spago build --backend-args "--main App --ffi bak/php/ffi" || echo "Compilation failed, but that's expected for now!"

echo "=== Native PHP ==="
if [ -f "output/main.php" ]; then
    php bin/php/composer.phar update --no-plugins -d output
    echo "<?php require __DIR__ . '/vendor/autoload.php'; require 'main.php';" > output/run.php
    mkdir -p /tmp/phpurs_opcache
    time php -d xdebug.mode=off -d opcache.enable_cli=1 -d opcache.file_cache=/tmp/phpurs_opcache -d opcache.jit_buffer_size=128M -d opcache.jit=1255 output/run.php
else
    echo "No output/main.php generated."
fi
