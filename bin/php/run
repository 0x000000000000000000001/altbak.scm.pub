#!/usr/bin/env bash
set -e
cd "$(dirname "$0")/../.."

mkdir -p run/bak/php/output run/bak/php/spago
rm -rf output .spago spago.yaml spago.lock
ln -s run/bak/php/output output
ln -s run/bak/php/spago .spago
ln -s run/bak/php/spago.yaml spago.yaml
touch run/bak/php/spago.lock && ln -s run/bak/php/spago.lock spago.lock

ENTRY_POINT="App"

if [ "$1" == "--x" ]; then
  ENTRY_POINT="AppX"
  # Temporarily inject extended tests
  cp -r srx/Test/* src/Test/
  cp srx/AppX.purs src/
  trap "rm -rf src/Test/STArray.purs src/Test/AffOperations.purs src/Test/StringOps.purs src/Test/FileOps src/AppX.purs" EXIT
fi

if [ -f "composer.base.json" ]; then
  cp composer.base.json composer.json
fi

export PATH="$PWD/run/bak/js/node_modules/.bin:$PATH"
spago build --backend-args "--main ${ENTRY_POINT} --ffi run/bak/php/ffi" || echo "Compilation failed, but that's expected for now!"

if [ -f "composer.json" ]; then
  rm composer.json
fi

echo "=== Native PHP ==="
if [ -f "output/main.php" ]; then
    mv output/composer.json run/bak/php/composer.json
    php bin/php/composer.phar update --no-plugins -d run/bak/php
    echo "<?php require __DIR__ . '/../vendor/autoload.php'; require 'main.php';" > output/run.php
    mkdir -p /tmp/phpurs_opcache
    time php -d xdebug.mode=off -d opcache.enable_cli=1 -d opcache.file_cache=/tmp/phpurs_opcache -d opcache.jit_buffer_size=128M -d opcache.jit=1255 output/run.php
else
    echo "No output/main.php generated."
fi
